generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
}

enum OrderStatus {
  PENDING_WHATSAPP
  CONFIRMED
  CANCELLED
}

enum AccessoryCategory {
  VELAS
  SEPARADORES
  TRES_D
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  rol          Role      @default(ADMIN)
  activo       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model Book {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  isbn          String       @unique @db.VarChar(20)
  title         String       @db.VarChar(255)
  originalTitle String?      @map("original_title") @db.VarChar(255)
  googleBooksId String?      @unique @map("google_books_id") @db.VarChar(100)
  publishedDate String?      @map("published_date") @db.VarChar(50)
  language      String?      @db.VarChar(10)
  authors       BookAuthor[]
  synopsis      String?      @db.Text
  coverUrl      String?      @map("cover_url")
  price         Decimal      @db.Decimal(12, 2)
  stock         Int          @default(0)
  badge         String?      @db.VarChar(50) // Ej: "2x1", "Últimas unidades", "Oferta"
  genre         String?      @db.VarChar(100)
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  combos        ComboBook[]

  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([originalTitle(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([isActive, stock])
  @@map("books")
}

model Author {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String       @unique @db.VarChar(255)
  books     BookAuthor[]
  createdAt DateTime     @default(now()) @map("created_at")

  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("authors")
}

model BookAuthor {
  bookId   String @db.Uuid @map("book_id")
  authorId String @db.Uuid @map("author_id")
  book     Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author   Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@id([bookId, authorId])
  @@map("book_authors")
}

model Accessory {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String            @db.VarChar(255)
  description String?           @db.Text
  price       Decimal           @db.Decimal(12, 2)
  stock       Int               @default(0)
  category    AccessoryCategory
  coverUrl    String?           @map("cover_url")
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  combos      ComboAccessory[]

  @@map("accessories")
}

model Combo {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String           @db.VarChar(255)
  description String?          @db.Text
  price       Decimal          @db.Decimal(12, 2)
  coverUrl    String?          @map("cover_url")
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  books       ComboBook[]
  accessories ComboAccessory[]

  @@map("combos")
}

model ComboBook {
  comboId  String @db.Uuid @map("combo_id")
  bookId   String @db.Uuid @map("book_id")
  quantity Int    @default(1)
  combo    Combo  @relation(fields: [comboId], references: [id], onDelete: Cascade)
  book     Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@id([comboId, bookId])
  @@map("combo_books")
}

model ComboAccessory {
  comboId     String    @db.Uuid @map("combo_id")
  accessoryId String    @db.Uuid @map("accessory_id")
  quantity    Int       @default(1)
  combo       Combo     @relation(fields: [comboId], references: [id], onDelete: Cascade)
  accessory   Accessory @relation(fields: [accessoryId], references: [id], onDelete: Cascade)

  @@id([comboId, accessoryId])
  @@map("combo_accessories")
}

model OrderLead {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerName  String      @map("customer_name") @db.VarChar(150)
  customerPhone String      @map("customer_phone") @db.VarChar(50)
  customerEmail String      @map("customer_email") @db.VarChar(255)
  customerDni   String      @map("customer_dni") @db.VarChar(20)
  postalCode    String?     @map("postal_code") @db.VarChar(20)
  address       String?
  items         Json
  totalAmount   Decimal     @map("total_amount") @db.Decimal(12, 2)
  status        OrderStatus @default(PENDING_WHATSAPP)
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("order_leads")
}

model StoreConfig {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  whatsappPhone   String   @default("5493876235245") @db.VarChar(50)
  instagramUrl    String   @default("https://www.instagram.com/alma.lectora.al/?hl=es-la") @db.VarChar(255)
  shippingCost    Decimal  @default(0.00) @db.Decimal(12, 2)
  freeShippingMin Decimal  @default(0.00) @db.Decimal(12, 2)
  bannerMessage   String?  @db.Text
  isStoreOpen     Boolean  @default(true)
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("store_config")
}

